# ============================================
# TrendRadar 环境变量配置
# ============================================

# 运行模式
ENABLE_WEBSERVER=false
WEBSERVER_PORT=8080
WEBSERVER_WATCHDOG=true
WEBSERVER_WATCHDOG_INTERVAL=60

# 飞书机器人 Webhook（多账号用 ; 分隔）
# 获取方式：飞书群 → 设置 → 群机器人 → 添加机器人 → Custom Bot
FEISHU_WEBHOOK_URL=

# 定时推送（推荐 morning_evening：早8点 + 晚18点）
CRON_SCHEDULE=*/30 * * * *
RUN_MODE=cron
IMMEDIATE_RUN=true

# AI 分析（可选，不填则只做关键词过滤，不做 AI 摘要）
AI_ANALYSIS_ENABLED=false
# AI_API_KEY=
# AI_MODEL=deepseek/deepseek-chat
# AI_API_BASE=
